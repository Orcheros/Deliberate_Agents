# Deliberate_Agents Integrations — Environment Variables
#
# Each integration directory has its own .env.example listing the
# variables it needs. This top-level file aggregates them all.
#
# Copy this to .env and fill in your values, or export in ~/.zshrc.
# NEVER commit the .env file — it is gitignored.

# --- Slack (integrations/slack/) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
